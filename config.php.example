<?php
/**
 * Configuration for imapfilter-ui
 * Copy this file as config.php and adjust the values below.
 * IMPORTANT: Never commit config.php to the Git repository!
 */

/////////////////////////////
// Paths to Lua config files
/////////////////////////////

// Base directory for imapfilter configuration files
// Default: /srv/imapfilter — adjust if you store them elsewhere
$luaBaseDir   = '/srv/imapfilter';

// Individual files (derived from $luaBaseDir)
$filtersFile  = $luaBaseDir . '/filters.lua';
$foldersFile  = $luaBaseDir . '/folders.lua';

// Backup directory (must be writable by the web server)
$backupDir    = $luaBaseDir . '/backups';

// Path to the imapfilter binary and main config
$imapfilterBin    = '/usr/bin/imapfilter';
$imapfilterConfig = $luaBaseDir . '/config.lua';

/////////////////////////////
// Web UI login credentials
/////////////////////////////

// Username for the web UI login
define('IMAPFILTER_UI_USER', 'your-username');

// Generate a password hash on the shell:
// php -r "echo password_hash('YOUR_PASSWORD', PASSWORD_DEFAULT), PHP_EOL;"
define('IMAPFILTER_UI_PASSWORD_HASH', 'PASTE_HASH_HERE');
