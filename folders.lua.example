-- ===== Folder References =====
-- Copy this file as folders.lua and adjust it to your needs.
-- Path: /srv/imapfilter/folders.lua (or as defined in config.php)

-- Required folders (always present)
inbox      = account['INBOX']
spamfolder = account['Spam']

-- Custom folders (adjust or extend as needed)
family_root     = account['Family']
work            = account['Work']
newsletter_root = account['Newsletter']

